// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AreaType {
  URBAN
  RURAL
}

enum RoleName {
  CITIZEN
  AUTHORITY
  ADMIN
}

enum JurisdictionType {
  STATE
  DISTRICT
  CITY
  ZONE
  WARD
  BLOCK
  PANCHAYAT
}

enum JurisdictionCategory {
  URBAN
  RURAL
}

enum NotificationType {
  ISSUE_STATUS
  ISSUE_REMARK
  ISSUE_ASSIGNED
  ISSUE_FORWARDED
  ISSUE_RESOLVED
  ISSUE_CLOSED
  MONTHLY_REPORT
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  passwordHash           String?
  isActive               Boolean   @default(true)
  name                   String?
  phone                  String?
  gender                 String?
  idType                 String?
  idNumber               String?
  aadhaarNumber          String?
  jurisdictionId         String?
  addressDistrict        String?
  addressCityOrPanchayat String?
  addressAreaType        AreaType?
  addressWard            String?
  addressLocality        String?
  addressLandmark        String?
  addressText            String?
  profileImageUrl        String?
  pinCode                String?
  addressLat             Float?
  addressLng             Float?
  createdAt              DateTime  @default(now())

  jurisdiction   Jurisdiction?    @relation(fields: [jurisdictionId], references: [id])
  issues         Issue[]
  votes          Vote[]
  userRoles      UserRole[]
  authorityProfile AuthorityProfile?
  issueUpdates   IssueUpdate[]
  activityEvents UserActivityEvent[]
  notifications  Notification[]
  deviceTokens   DeviceToken[]
  actorNotifications Notification[] @relation("NotificationActor")

  @@map("users")
}

model UserActivityEvent {
  id          Int      @id @default(autoincrement())
  userId      String
  type        String
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_activity_events")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      RoleName @unique
  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  userId     String
  roleId     Int
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Jurisdiction {
  id        String               @id @default(uuid())
  name      String
  type      JurisdictionType
  category  JurisdictionCategory
  parentId  String?
  pincode   String?
  createdAt DateTime             @default(now())

  parent            Jurisdiction?      @relation("JurisdictionHierarchy", fields: [parentId], references: [id])
  children          Jurisdiction[]     @relation("JurisdictionHierarchy")
  users             User[]
  issues            Issue[]
  authorityProfiles AuthorityProfile[]

  @@index([parentId])
  @@map("jurisdictions")
}

model Category {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  issues Issue[]

  @@map("categories")
}

model Issue {
  id        Int     @id @default(autoincrement())
  clientId  String  @unique // For offline-first support
  userId    String
  categoryId Int?
  title     String
  description String
  addressText String?
  landmark  String?
  locality  String?
  imageUrl  String?
  lat       Float
  lng       Float
  status    String  @default("open")
  priority  String  @default("medium")
  departmentId Int?
  jurisdictionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id])
  votes      Vote[]
  department Department? @relation(fields: [departmentId], references: [id])
  jurisdiction Jurisdiction? @relation(fields: [jurisdictionId], references: [id])
  updates    IssueUpdate[]
  images     IssueImage[]
  notifications Notification[]

  @@index([jurisdictionId, createdAt])
  @@index([departmentId, createdAt])
  @@index([status, createdAt])
  @@index([categoryId])
  @@map("issues")
}

model Vote {
  userId  String
  issueId Int
  createdAt DateTime @default(now())

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@id([userId, issueId])
  @@map("votes")
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  otpHash   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("otps")
}

model Department {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  issues            Issue[]
  authorityProfiles AuthorityProfile[]
  issueUpdatesFrom  IssueUpdate[]      @relation("IssueUpdateFromDepartment")
  issueUpdatesTo    IssueUpdate[]      @relation("IssueUpdateToDepartment")

  @@map("departments")
}

model Designation {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  authorityProfiles AuthorityProfile[]

  @@map("designations")
}

model AuthorityProfile {
  userId         String   @id
  designationId  Int
  departmentId   Int
  jurisdictionId String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  designation  Designation  @relation(fields: [designationId], references: [id])
  department   Department   @relation(fields: [departmentId], references: [id])
  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id])

  @@index([jurisdictionId, designationId])
  @@index([departmentId])
  @@map("authority_profiles")
}

model IssueUpdate {
  id               Int      @id @default(autoincrement())
  issueId          Int
  actorUserId      String?
  fromDepartmentId Int?
  toDepartmentId   Int?
  oldStatus        String?
  newStatus        String?
  type             String?
  message          String   @default("")
  remarks          String?
  proofImageUrl    String?
  visibleToCitizen Boolean  @default(true)
  createdAt        DateTime @default(now())

  issue          Issue        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actor          User?        @relation(fields: [actorUserId], references: [id])
  fromDepartment Department?  @relation("IssueUpdateFromDepartment", fields: [fromDepartmentId], references: [id])
  toDepartment   Department?  @relation("IssueUpdateToDepartment", fields: [toDepartmentId], references: [id])
  notifications  Notification[]

  @@index([issueId, createdAt])
  @@map("issue_updates")
}

model IssueImage {
  id        String   @id @default(uuid())
  issueId   Int
  imageUrl  String
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@map("issue_images")
}

model Notification {
  id               String           @id @default(uuid())
  userId           String
  type             NotificationType
  title            String
  body             String
  isRead           Boolean          @default(false)
  issueId          Int?
  issueUpdateId    Int?
  actorUserId      String?
  actorDisplayName String?
  metadata         Json?
  readAt           DateTime?
  createdAt        DateTime         @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor     User?       @relation("NotificationActor", fields: [actorUserId], references: [id])
  issue     Issue?      @relation(fields: [issueId], references: [id], onDelete: SetNull)
  issueUpdate IssueUpdate? @relation(fields: [issueUpdateId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([issueId, createdAt])
  @@map("notifications")
}

model DeviceToken {
  id         String         @id @default(uuid())
  userId     String
  token      String         @unique
  platform   DevicePlatform
  isActive   Boolean        @default(true)
  lastSeenAt DateTime       @default(now())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("device_tokens")
}
